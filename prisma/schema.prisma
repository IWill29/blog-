generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  date      DateTime
  summary   String?
  image     String?
  tags      String[]
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Person {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  occupation String?
  company    String?
  email      String?
  twitter    String?
  linkedin   String?
  github     String?
  avatar     String?
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteSettings {
  id          String   @id @default("default")
  siteName    String?
  headerTitle String?
  logoImage   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
